{
  "name": "newtab-extension",
  "version": "16.5",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/bump-version.mjs",
    "build": "bash scripts/build.sh",
    "build:chrome": "bash scripts/build.sh",
    "build:firefox": "bash scripts/build.sh",
    "build:safari": "bash scripts/build.sh",
    "check": "biome check src scripts tests *.json",
    "lint": "biome lint src scripts tests *.json",
    "format": "biome format --write src scripts tests *.json",
    "test": "node --test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4"
  }
}
